# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
build/
dist/
.venv/
venv/
.env

# Editors
.vscode/
.idea/
.ipynb_checkpoints/

# OS noise
.DS_Store
Thumbs.db
# Excel lock files
~$*

# Ad-hoc scratch / one-off diagnostics — never committed (see DEV_ARTIFACTS.md)
/_scratch/

# Golden-master snapshots are derived from market data and regenerated locally.
tests/golden/*.json

# Output: keep the folder in the repo, ignore all generated run artifacts
# (per-run run_<date>/ folders, batch_*.{log,json}, stale flat-layout files).
/output/*
!/output/.gitkeep

# Additional outputs routed to the Email channel (generated each run).
/email/

# Decisions:
#   data/curves/market_environment_*.csv  -- TRACKED (raw production curve export)
#   /output/                              -- folder kept, artifacts ignored (regenerated each run)
#   data/trades/                          -- already tracked
#   data/fixings/                         -- TRACKED (uploaded to the repo)

# Coding-time reference specs/intake — never ship
/additional output templates/
