# Single-trade YAML template. To activate: copy this file, rename without ".sample"
# (e.g. SWAP_TEST_001.yaml), and edit the fields below.
#
# Required fields are unindented. Optional fields show their defaults in comments.

trade_id: SWAP_TEST_001          # unique label
notional: 500000000              # positive number
pay_fixed: false                 # true = pay fixed/receive float; false = receive fixed/pay float
fixed_rate: 0.0541               # decimal, 0.0541 = 5.41%
start_date: 2026-03-09           # ISO date, first accrual day
maturity_date: 2031-03-09        # ISO date, last accrual end
fixed_frequency: 1M              # 1Y / 6M / 3M / 1M / 1W / 1D
fixed_daycount: ACT/360          # ACT/360 | ACT/365F | 30/360 | 30E/360 | ACT/ACT-ISDA

# --- Optional (defaults shown) ---
floating_daycount: ACT/360
floating_spread: 0.0

# Principal exchange -- configurable per leg. Allowed values:
#   none   (default) -- no principal flows
#   start            -- -notional at start_date (paid out at issuance)
#   end              -- +notional at final payment date (received at maturity)
#   both             -- both rows
# Sign convention works with `pay_fixed` so the cashflow lands on the right side.
fixed_principal_exchange: none
floating_principal_exchange: none

fixing_calendar: NY_FED
payment_calendar: NY_FED
payment_delay_bdays: 2           # business-day lag from accrual end to cash payment
lockout_bdays: 0
business_day_convention: ModifiedFollowing      # global fallback for per-leg rolls below

# --- Per-leg roll conventions (optional) ---
# Each accepts: None / NoAdjust / Following / ModifiedFollowing (default) /
#               Preceding / ModifiedPreceding / Nearest.
# Leave blank ("") to fall back to `business_day_convention` above.
#
# Fixed leg rolls
#   fixed_spot_roll: ""                 # rolls the unadjusted effective/start date
#   fixed_accrual_roll: ""              # rolls each unadjusted accrual end
#   fixed_pay_roll: ""                  # rolls each unadjusted payment date
#
# Floating leg rolls
#   floating_accrual_roll: ""           # rolls each unadjusted accrual end
#   floating_pay_roll: ""               # rolls each unadjusted payment date
#   floating_fixing_roll: Preceding     # rolls the lookback-shifted observation date
#   floating_fixing_lag_bdays: 0        # OIS lookback in BDs (0 = rate set in advance)

description: "Free text — optional, retained in the SwapValuation meta dict."

# --- Advanced: per-trade calendar customization (optional) ---
# fixing_calendar_extras:                # inline list of extra holidays on top of NY_FED
#   - 2026-07-06
# fixing_calendar_extras_file: ...       # path to CSV/TXT/XLSX with a 'date' column
# payment_calendar_extras: [...]
# payment_calendar_extras_file: ...
