# Trade template (YAML) -- Bloomberg-matched conventions.
# Copy to data/trades/<id>.yaml (no .sample) and edit.
# Every convention is PER-LEG. Only economic terms are shared.

# --- Required (economic terms) ---
trade_id: SWAP_001
notional: 500000000
pay_fixed: true                  # true = pay fixed / receive float
fixed_rate: 0.0400
start_date: 2026-03-09           # ISO date, effective date
maturity_date: 2031-03-09        # ISO date, termination date
fixed_frequency: 1M              # 1Y / 6M / 3M / 1M / 1W / 1D
fixed_daycount: ACT/360          # ACT/360 | ACT/365F | 30/360 | 30E/360 | ACT/ACT-ISDA

# --- Fixed leg conventions (Bloomberg vocabulary) ---
fixed_bus_day_adj: ModifiedFollowing   # Bloomberg "Bus Day Adj"
fixed_eff_date_adj:                    # "Eff Date Adj"; blank => fixed_bus_day_adj
fixed_pay_date_adj:                    # "Pay Date Adj"; blank => fixed_bus_day_adj (Bloomberg-derived)
fixed_adjust: acc_and_pay              # acc_and_pay | pay | none
fixed_roll_convention: forward_eom     # forward | forward_eom | backward | backward_eom
fixed_payment_delay_bdays: 0
fixed_principal_exchange: none         # none | start | end | both
fixed_calculation_calendar: NY_FED
fixed_payment_calendar:                # blank => fixed_calculation_calendar (Bloomberg-derived)

# --- Floating leg conventions ---
floating_frequency:                    # blank => fixed_frequency (standard OIS)
floating_daycount: ACT/360
floating_spread: 0.0
floating_bus_day_adj: ModifiedFollowing
floating_eff_date_adj:                 # blank => floating_bus_day_adj
floating_pay_date_adj:                 # blank => floating_bus_day_adj (Bloomberg-derived)
floating_rst_bus_day_adj:              # "Rst Bus Day Adj"; blank => floating_bus_day_adj
floating_adjust: acc_and_pay           # acc_and_pay | pay | none
floating_roll_convention: forward_eom
floating_payment_delay_bdays: 0
floating_reset_lag_bdays: 0            # business-day lookback; 0 = in-arrears OIS (Bloomberg-derived)
floating_lockout_bdays: 0
floating_principal_exchange: none
floating_calculation_calendar: NY_FED
floating_fixing_calendar: NY_FED       # reset/fixing calendar
floating_payment_calendar:             # blank => floating_calculation_calendar (Bloomberg-derived)

# Roll values everywhere: None / NoAdjust / Following / ModifiedFollowing /
#   Preceding / ModifiedPreceding / Nearest.
# Optional per-leg holiday extras (inline list or file):
#   fixed_calculation_calendar_extras: [2027-12-24]
#   floating_fixing_calendar_extras_file: extras/fed_closures.csv
